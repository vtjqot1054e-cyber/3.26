# Cursor索引忽略文件
# 防止Cursor索引大文件/无关目录导致卡死

# OB Copilot索引文件（227MB超大文件，存在两份副本）
vault/.obsidian/plugins/copilot/
vault/.obsidian/copilot-index-*.json
copilot/

# Smart Connections索引文件（131个ajson，Cursor不需要读）
.smart-env/
vault/.smart-env/

# 向量数据库（二进制，不可索引）
vault/knowledge_base/vector_store/
knowledge_base/vector_store/

# Git对象（二进制大文件）
.git/objects/
.git/cursor/

# 废弃目录（已迁移，不再使用）
# 注意：/开头确保只匹配根目录，不会误伤vault/数字分身/
/数字分身-废弃/
/数字分身/

# 临时文件
temp_*.txt
temp_*.json
temp_*.md
error.txt
output.txt
_diff_result.txt
temp_archive.txt
temp_check.txt

# 对话导出（MD文件太多，Cursor索引极慢）
vault/数字分身/对话导出/

# SpecStory历史（双保险，.cursorindexingignore已覆盖）
.specstory/history/

# 二进制/PDF
*.pdf
*.bin
*.pack
*.idx

# Node依赖
node_modules/